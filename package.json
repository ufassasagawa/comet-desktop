{
  "name": "comet-desktop",
  "version": "0.1.0",
  "description": "Comet ☄️ デスクトップ・オーバーレイ (Mac / Windows)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "icons": "electron build/gen-icons.js",
    "dist": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "license": "MIT",
  "type": "commonjs",
  "build": {
    "appId": "co.ufas.comet",
    "productName": "Comet",
    "files": [
      "main.js",
      "assets/**"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.social-networking"
    },
    "dmg": {
      "artifactName": "Comet-${version}.dmg"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon-1024.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "Comet-Setup-${version}.exe"
    }
  },
  "devDependencies": {
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1"
  }
}
